#!/bin/bash
# ============================================================
# 실행하기.command - 더블클릭으로 프로그램 실행
# ============================================================
# macOS에서 .command 파일은 더블클릭하면 터미널이 열리면서
# 자동으로 실행됩니다.
# ============================================================

# 이 스크립트가 있는 폴더로 이동합니다
# (어디서 더블클릭해도 올바른 경로에서 실행되도록)
cd "$(dirname "$0")"

echo "================================================="
echo " JEUS 서버 로그 분석기 시작 중..."
echo "================================================="
echo ""

# 가상환경(venv) 폴더가 없으면 처음 한 번만 만듭니다
if [ ! -d "venv" ]; then
    echo "[준비] 처음 실행 시 필요한 환경을 설치합니다 (1~2분 소요)..."
    python3 -m venv venv
    source venv/bin/activate
    pip install openpyxl --quiet
    echo "[준비] 설치 완료!"
    echo ""
else
    # 이미 만들어진 가상환경을 불러옵니다
    source venv/bin/activate
fi

# 프로그램 실행
echo "[실행] 프로그램을 시작합니다..."
python3 main.py

echo ""
echo "프로그램이 종료되었습니다."
